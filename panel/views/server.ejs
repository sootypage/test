<%- include('layout-top', { title }) %>
<section class="hero">
  <div>
    <h1><%= server.name %></h1>
    <p><%= server.game %> on <%= node ? node.name : 'Unknown node' %> · <%= server.ipAddress || 'IP not set' %>:<%= server.port %></p>
  </div>
  <div class="status <%= live && live.state && live.state.Running ? 'online' : 'offline' %>">
    <%= live && live.state && live.state.Running ? 'Online' : 'Offline' %>
  </div>
</section>

<section class="grid-2">
  <div class="card">
    <h2>Resource usage</h2>
    <div class="resource-grid">
      <div><strong id="cpuStat"><%= live && live.stats && live.stats.docker ? live.stats.docker.cpuPercent : '0%' %></strong><span>CPU</span></div>
      <div><strong id="ramStat"><%= live && live.stats && live.stats.docker ? live.stats.docker.memoryUsage : '0B / 0B' %></strong><span>RAM</span></div>
      <div><strong id="storageStat"><%= live && live.stats && live.stats.storage ? Math.ceil(live.stats.storage.usedBytes / 1024 / 1024) + ' MB / ' + (live.stats.storage.limitMb || 0) + ' MB' : '0 MB' %></strong><span>Storage</span></div>
      <div><strong id="diskStat"><%= live && live.stats && live.stats.storage && live.stats.storage.disk && live.stats.storage.disk.availableBytes ? Math.floor(live.stats.storage.disk.availableBytes / 1024 / 1024 / 1024) + ' GB free' : 'Unknown' %></strong><span>Node disk</span></div>
    </div>
  </div>
  <div class="card">
    <h2>Server limits</h2>
    <div class="chips">
      <span>RAM <%= server.memoryMb %> MB</span>
      <span>CPU <%= server.cpuLimit || 1 %></span>
      <span>Storage <%= server.storageLimitMb || 0 %> MB</span>
      <span>Join: <%= server.ipAddress || 'IP not set' %>:<%= server.port %></span>
    </div>
    <div class="button-row mt-12">
      <form method="post" action="/servers/<%= server.id %>/action"><button name="action" value="start" class="primary">Start</button></form>
      <form method="post" action="/servers/<%= server.id %>/action"><button name="action" value="restart">Restart</button></form>
      <form method="post" action="/servers/<%= server.id %>/action"><button name="action" value="stop" class="danger">Stop</button></form>
    </div>
  </div>
</section>

<section class="tab-bar card">
  <button class="tab-btn active" data-tab="console">Console</button>
  <button class="tab-btn" data-tab="files">File manager</button>
  <button class="tab-btn" data-tab="ftp">FTP / SFTP</button>
  <button class="tab-btn" data-tab="saves">Saves</button>
  <button class="tab-btn" data-tab="backups">Backups</button>
  <button class="tab-btn" data-tab="addons">Plugins / Mods</button>
  <button class="tab-btn" data-tab="settings">Settings</button>
  <button class="tab-btn" data-tab="subusers">Subusers</button>
  <button class="tab-btn" data-tab="network">Network</button>
  <button class="tab-btn" data-tab="subdomains">Subdomains</button>
  <button class="tab-btn" data-tab="database">Database</button>
</section>

<section id="tab-console" class="tab-panel active">
  <div class="card">
    <div class="card-title-row">
      <h2>Live console logs</h2>
      <button type="button" onclick="loadLogs()">Refresh</button>
    </div>
    <div class="command-wrap">
      <form method="post" action="/servers/<%= server.id %>/command" class="command-form">
        <input name="command" placeholder="say hello from the panel" required>
        <button>Send</button>
      </form>
    </div>
    <% if (live && live.error) { %>
      <pre id="consoleBox" class="console"><%= live.error %></pre>
    <% } else { %>
      <pre id="consoleBox" class="console"><%= live && live.logs ? live.logs : 'No logs yet.' %></pre>
    <% } %>
    <p class="muted small">Shows server startup, joins, leaves, chat, warnings, and more. Auto-refreshes every 5 seconds.</p>
  </div>
</section>

<section id="tab-files" class="tab-panel">
  <div class="card">
    <div class="card-title-row">
      <h2>File manager</h2>
      <div class="path-pill">/<%= files && files.path ? files.path : '' %></div>
    </div>

    <% if (files && files.error) { %><p class="error"><%= files.error %></p><% } %>

    <div class="file-actions">
      <form method="get" action="/servers/<%= server.id %>" class="inline-form-wide">
        <input type="hidden" name="tab" value="files">
        <input name="path" value="<%= files && files.path ? files.path : '' %>" placeholder="folder/path">
        <button>Open path</button>
      </form>
      <% if (files && files.path) { %>
        <a class="button" href="/servers/<%= server.id %>?path=<%= encodeURIComponent(files.parent || '') %>#files">Up</a>
      <% } %>
    </div>

    <div class="file-actions">
      <form method="post" action="/servers/<%= server.id %>/files/upload" enctype="multipart/form-data" class="inline-form-wide multi-upload-form">
        <input type="hidden" name="path" value="<%= files && files.path ? files.path : '' %>">
        <input type="file" name="files" multiple required>
        <label class="small"><input type="checkbox" name="extractZip" value="true"> unzip .zip after upload</label>
        <label class="small"><input type="checkbox" name="deleteZipAfterExtract" value="true"> delete zip</label>
        <button class="primary">Upload files</button>
      </form>
      <form method="post" action="/servers/<%= server.id %>/files/mkdir" class="inline-form-wide">
        <input type="hidden" name="path" value="<%= files && files.path ? files.path : '' %>">
        <input name="name" placeholder="new-folder" required>
        <button>Create folder</button>
      </form>
    </div>

    <table>
      <thead><tr><th>Name</th><th>Type</th><th>Size</th><th>Modified</th><th>Actions</th></tr></thead>
      <tbody>
        <% (files && files.items ? files.items : []).forEach(item => { %>
          <tr>
            <td>
              <% if (item.type === 'dir') { %>
                📁 <a href="/servers/<%= server.id %>?path=<%= encodeURIComponent(item.path) %>#files"><%= item.name %></a>
              <% } else { %>
                📄 <%= item.name %>
              <% } %>
            </td>
            <td><%= item.type %></td>
            <td><%= item.size %></td>
            <td><%= new Date(item.modifiedAt).toLocaleString() %></td>
            <td class="actions-cell">
              <% if (item.type === 'file') { %>
                <a href="/servers/<%= server.id %>/files/download?path=<%= encodeURIComponent(item.path) %>">Download</a>
                <a href="/servers/<%= server.id %>/files/edit?path=<%= encodeURIComponent(item.path) %>">Edit</a>
                <% if (/\.zip$/i.test(item.name)) { %>
                  <form method="post" action="/servers/<%= server.id %>/files/unzip" onsubmit="return confirm('Unzip <%= item.name %> here?')">
                    <input type="hidden" name="path" value="<%= item.path %>">
                    <input type="hidden" name="currentPath" value="<%= files && files.path ? files.path : '' %>">
                    <button class="small-btn">Unzip</button>
                  </form>
                <% } %>
              <% } else { %>
                <a href="/servers/<%= server.id %>/files/download?path=<%= encodeURIComponent(item.path) %>">Download folder</a>
              <% } %>
              <form method="post" action="/servers/<%= server.id %>/files/delete" onsubmit="return confirm('Delete <%= item.name %>?')">
                <input type="hidden" name="path" value="<%= item.path %>">
                <input type="hidden" name="currentPath" value="<%= files && files.path ? files.path : '' %>">
                <button class="danger small-btn">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (!(files && files.items && files.items.length)) { %>
          <tr><td colspan="5" class="muted">No files found. If this used to show files, restart the agent or check the server folder path in the agent database.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>

<section id="tab-ftp" class="tab-panel">
  <div class="card">
    <h2>FTP / SFTP access</h2>
    <p class="muted">This uses one shared SFTP port for all users. Each server gets its own username and password and is restricted to that server folder.</p>
    <% if (ftp && ftp.error) { %><p class="error"><%= ftp.error %></p><% } %>
    <div class="resource-grid">
      <div><strong><%= ftp && ftp.enabled ? 'Enabled' : 'Disabled' %></strong><span>Status</span></div>
      <div><strong><%= ftp && ftp.port ? ftp.port : '2222' %></strong><span>SFTP port</span></div>
      <div><strong><%= server.ipAddress || node.publicIp || 'Node IP' %></strong><span>Host</span></div>
      <div><strong><%= ftp && ftp.username ? ftp.username : 'Not created' %></strong><span>Username</span></div>
    </div>
    <% if (ftp && ftp.enabled) { %>
      <div class="card inner-card">
        <p><strong>Host:</strong> <code><%= server.ipAddress || node.publicIp || 'YOUR_NODE_IP' %></code></p>
        <p><strong>Port:</strong> <code><%= ftp.port %></code></p>
        <p><strong>Protocol:</strong> <code>SFTP</code></p>
        <p><strong>Username:</strong> <code><%= ftp.username %></code></p>
        <p><strong>Password:</strong> <code><%= ftp.password %></code></p>
        <p class="muted small">Use FileZilla, WinSCP, or another SFTP client. Use SFTP, not normal FTP.</p>
      </div>
    <% } %>
    <div class="button-row">
      <form method="post" action="/servers/<%= server.id %>/ftp/reset" onsubmit="return confirm('Create/reset SFTP password for this server?')">
        <button class="primary">Create / reset SFTP login</button>
      </form>
      <form method="post" action="/servers/<%= server.id %>/ftp/disable" onsubmit="return confirm('Disable SFTP access for this server?')">
        <button class="danger">Disable SFTP</button>
      </form>
    </div>
    <p class="muted small">Open the shared SFTP port on the node firewall: <code>sudo ufw allow 2222/tcp</code>. You can change it in agent/.env with <code>SFTP_PORT=2222</code>.</p>
  </div>
</section>

<section id="tab-saves" class="tab-panel">
  <div class="card">
    <div class="card-title-row">
      <div>
        <h2>Upload saves / worlds</h2>
        <p class="muted">Upload a zipped Minecraft world. Use replace only when you are sure.</p>
      </div>
    </div>
    <form method="post" action="/servers/<%= server.id %>/saves/upload" enctype="multipart/form-data" class="form settings-grid">
      <label>World folder name</label>
      <input name="worldName" value="world" placeholder="world">
      <label>Mode</label>
      <select name="mode">
        <option value="new">Upload into world folder / merge</option>
        <option value="replace">Replace the folder first</option>
      </select>
      <label>Save archive</label>
      <input type="file" name="save" accept=".zip,.tar.gz,.tgz" required>
      <div class="span"><button class="primary">Upload save</button></div>
    </form>
    <p class="muted small">Supported: .zip, .tar.gz, .tgz. Stop the server before replacing a world to avoid file corruption.</p>
    <hr class="soft-sep">
    <h3>Download world folder</h3>
    <form method="get" action="/servers/<%= server.id %>/saves/world/download" class="form settings-grid">
      <label>World folder name</label>
      <input name="worldName" value="world" placeholder="world">
      <div class="span"><button>Download world as .tar.gz</button></div>
    </form>
  </div>
</section>

<section id="tab-backups" class="tab-panel">
  <div class="card">
    <div class="card-title-row">
      <h2>Backups</h2>
      <form method="post" action="/servers/<%= server.id %>/backups/create">
        <button class="primary">Create backup</button>
      </form>
    </div>
    <% if (backups && backups.error) { %><p class="error"><%= backups.error %></p><% } %>
    <table>
      <thead><tr><th>Name</th><th>Size</th><th>Created</th><th>Actions</th></tr></thead>
      <tbody>
      <% (backups && backups.backups ? backups.backups : []).forEach(b => { %>
        <tr>
          <td><%= b.name %></td>
          <td><%= b.size %></td>
          <td><%= new Date(b.createdAt).toLocaleString() %></td>
          <td class="actions-cell">
            <a href="/servers/<%= server.id %>/backups/<%= encodeURIComponent(b.name) %>">Download</a>
            <form method="post" action="/servers/<%= server.id %>/backups/restore" onsubmit="return confirm('Restore this backup? This will replace current server files.')">
              <input type="hidden" name="name" value="<%= b.name %>">
              <button class="small-btn">Restore</button>
            </form>
            <form method="post" action="/servers/<%= server.id %>/backups/delete" onsubmit="return confirm('Delete backup?')">
              <input type="hidden" name="name" value="<%= b.name %>">
              <button class="danger small-btn">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section id="tab-addons" class="tab-panel">
  <div class="card">
    <div class="card-title-row addons-header">
      <div>
        <h2>Plugin / Mod installer</h2>
        <p class="muted">Search Modrinth, Hangar, and Spigot/Spiget, or paste a direct jar URL.</p>
      </div>
    </div>

    <div class="plugin-searchbar">
      <input id="realAddonSearch" placeholder="Search plugins or mods, like LuckPerms, EssentialsX, Geyser">
      <select id="realAddonSource">
        <option value="all">All sources</option>
        <option value="modrinth">Modrinth</option>
        <option value="hangar">Hangar</option>
        <option value="spiget">Spigot/Spiget</option>
      </select>
      <button type="button" onclick="searchRealAddons()">Search</button>
    </div>

    <div class="sub-tabs">
      <button type="button" class="subtab-btn active" data-subtab="search">Search</button>
      <button type="button" class="subtab-btn" data-subtab="installed">Installed</button>
      <button type="button" class="subtab-btn" data-subtab="manual">Manual URL</button>
    </div>

    <div id="catalog-search" class="subtab-panel active">
      <div id="realAddonStatus" class="muted small">Search for plugins or mods above.</div>
      <div class="addon-grid" id="realAddonGrid"></div>

      <h3>Quick install picks</h3>
      <div class="addon-grid" id="addonGrid">
        <% pluginCatalog.forEach(item => { %>
          <div class="addon-card" data-search="<%= (item.name + ' ' + item.description + ' ' + item.type).toLowerCase() %>">
            <div class="addon-top">
              <div class="addon-icon"><%= item.type === 'mod' ? 'M' : 'P' %></div>
              <div>
                <h3><%= item.name %></h3>
                <p><%= item.description %></p>
              </div>
            </div>
            <form method="post" action="/servers/<%= server.id %>/installer" class="addon-action">
              <input type="hidden" name="type" value="<%= item.type %>">
              <input type="hidden" name="url" value="<%= item.url %>">
              <button><%= item.type === 'mod' ? 'Install mod' : 'Install plugin' %></button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>

    <div id="catalog-installed" class="subtab-panel">
      <div class="grid-2">
        <div class="card inner-card">
          <h3>Installed plugins</h3>
          <% if (plugins && plugins.error) { %><p class="error"><%= plugins.error %></p><% } %>
          <ul class="installed-list">
            <% (plugins && plugins.items ? plugins.items : []).filter(item => item.type === 'file').forEach(item => { %>
              <li>
                <span><%= item.name %></span>
                <span class="actions-cell">
                  <a href="/servers/<%= server.id %>/files/download?path=<%= encodeURIComponent(item.path) %>">Download</a>
                  <form method="post" action="/servers/<%= server.id %>/files/delete" onsubmit="return confirm('Uninstall <%= item.name %>? Restart after uninstalling.')">
                    <input type="hidden" name="path" value="<%= item.path %>">
                    <input type="hidden" name="currentPath" value="plugins">
                    <button class="danger small-btn">Uninstall</button>
                  </form>
                </span>
              </li>
            <% }) %>
            <% if (!(plugins && plugins.items && plugins.items.filter(item => item.type === 'file').length)) { %>
              <li class="muted">No plugins found yet.</li>
            <% } %>
          </ul>
        </div>
        <div class="card inner-card">
          <h3>Installed mods</h3>
          <% if (mods && mods.error) { %><p class="error"><%= mods.error %></p><% } %>
          <ul class="installed-list">
            <% (mods && mods.items ? mods.items : []).filter(item => item.type === 'file').forEach(item => { %>
              <li>
                <span><%= item.name %></span>
                <span class="actions-cell">
                  <a href="/servers/<%= server.id %>/files/download?path=<%= encodeURIComponent(item.path) %>">Download</a>
                  <form method="post" action="/servers/<%= server.id %>/files/delete" onsubmit="return confirm('Uninstall <%= item.name %>? Restart after uninstalling.')">
                    <input type="hidden" name="path" value="<%= item.path %>">
                    <input type="hidden" name="currentPath" value="mods">
                    <button class="danger small-btn">Uninstall</button>
                  </form>
                </span>
              </li>
            <% }) %>
            <% if (!(mods && mods.items && mods.items.filter(item => item.type === 'file').length)) { %>
              <li class="muted">No mods found yet.</li>
            <% } %>
          </ul>
        </div>
      </div>
    </div>

    <div id="catalog-manual" class="subtab-panel">
      <div class="card inner-card">
        <h3>Install from direct URL</h3>
        <form method="post" action="/servers/<%= server.id %>/installer" class="form two-col add-url-form">
          <label>Type</label>
          <select name="type">
            <option value="plugin">Plugin</option>
            <option value="mod">Mod</option>
          </select>
          <label>Download URL</label>
          <input name="url" placeholder="https://example.com/plugin.jar" required>
          <button class="primary span">Install from URL</button>
        </form>
      </div>
    </div>
  </div>
</section>

<section id="tab-settings" class="tab-panel">
  <div class="card">
    <div class="card-title-row"><h2>Server settings</h2><a class="button" href="/servers/<%= server.id %>/properties">Full server.properties editor</a></div>
    <% const s = settings && settings.settings ? settings.settings : {}; %>
    <% if (settings && settings.error) { %><p class="error"><%= settings.error %></p><% } %>
    <form method="post" action="/servers/<%= server.id %>/settings" class="form settings-grid">
      <label>Server type</label>
      <select name="serverType">
        <% ['PAPER','PURPUR','FABRIC','FORGE','NEOFORGE','VANILLA','VELOCITY','BUNGEECORD','WATERFALL','RUST','CUSTOM'].forEach(v => { %>
          <option value="<%= v %>" <%= String(s.type || 'PAPER').toUpperCase() === v ? 'selected' : '' %>><%= v %></option>
        <% }) %>
      </select>

      <label>Minecraft / game version</label>
      <input name="version" value="<%= s.version || 'LATEST' %>" placeholder="1.21.11 or LATEST">

      <label>MOTD</label>
      <input name="motd" value="<%= s.motd || server.name %>" placeholder="A Minecraft Server">

      <label>Custom JAR file</label>
      <input name="customServerJar" value="<%= (settings && settings.server && settings.server.env && settings.server.env.CUSTOM_SERVER) ? settings.server.env.CUSTOM_SERVER : '' %>" placeholder="server.jar or /data/server.jar">
      <p class="muted small span">For Custom JAR, upload your jar to the File Manager first. Default path is /data/server.jar.</p>

      <label>World seed</label>
      <input name="seed" value="<%= s.seed || '' %>" placeholder="Leave blank for random">

      <label>Level type</label>
      <input name="levelType" value="<%= s.levelType || 'minecraft:normal' %>">

      <label>Difficulty</label>
      <select name="difficulty">
        <% ['peaceful','easy','normal','hard'].forEach(v => { %>
          <option value="<%= v %>" <%= (s.difficulty || 'easy') === v ? 'selected' : '' %>><%= v %></option>
        <% }) %>
      </select>

      <label>Game mode</label>
      <select name="gameMode">
        <% ['survival','creative','adventure','spectator'].forEach(v => { %>
          <option value="<%= v %>" <%= (s.gameMode || 'survival') === v ? 'selected' : '' %>><%= v %></option>
        <% }) %>
      </select>

      <label>Max players</label>
      <input name="maxPlayers" type="number" value="<%= s.maxPlayers || 20 %>">

      <label>Spawn protection</label>
      <input name="spawnProtection" type="number" value="<%= s.spawnProtection || 16 %>">

      <label>View distance</label>
      <input name="viewDistance" type="number" value="<%= s.viewDistance || 10 %>">

      <label>Simulation distance</label>
      <input name="simulationDistance" type="number" value="<%= s.simulationDistance || 10 %>">

      <label>Online mode</label>
      <select name="onlineMode">
        <option value="true" <%= String(s.onlineMode || 'true') === 'true' ? 'selected' : '' %>>true</option>
        <option value="false" <%= String(s.onlineMode || 'true') === 'false' ? 'selected' : '' %>>false</option>
      </select>

      <label>PvP</label>
      <select name="pvp">
        <option value="true" <%= String(s.pvp || 'true') === 'true' ? 'selected' : '' %>>true</option>
        <option value="false" <%= String(s.pvp || 'true') === 'false' ? 'selected' : '' %>>false</option>
      </select>

      <label>Allow flight</label>
      <select name="allowFlight">
        <option value="true" <%= String(s.allowFlight || 'false') === 'true' ? 'selected' : '' %>>true</option>
        <option value="false" <%= String(s.allowFlight || 'false') === 'false' ? 'selected' : '' %>>false</option>
      </select>

      <div class="span">
        <button class="primary">Save settings</button>
      </div>
    </form>
    <p class="muted small">Changing the version recreates the Docker container. Changing the world seed only affects a new world or a reset world.</p>
    <hr class="soft-sep">
    <h3 class="danger-text">Danger zone</h3>
    <p class="muted small">Deleting this server removes the Docker container, files, backups, and the panel record. Type the server name to confirm.</p>
    <form method="post" action="/servers/<%= server.id %>/delete" class="form settings-grid" onsubmit="return confirm('Delete this server forever? This removes the Docker container and all files.')">
      <label>Type server name</label>
      <input name="confirmName" placeholder="<%= server.name %>" required>
      <div class="span"><button class="danger">Delete server forever</button></div>
    </form>
  </div>
</section>


<section id="tab-subusers" class="tab-panel">
  <div class="card">
    <div class="card-title-row"><h2>Subusers</h2><p class="muted">Give other panel users access to this server.</p></div>
    <form method="post" action="/servers/<%= server.id %>/subusers" class="form settings-grid">
      <label>User</label>
      <select name="userId">
        <% (allUsers || []).forEach(u => { %>
          <option value="<%= u.id %>"><%= u.email %> (<%= u.role %>)</option>
        <% }) %>
      </select>
      <label>Permissions</label>
      <div class="check-grid">
        <% ['console','files','backups','settings','power','addons'].forEach(p => { %>
          <label><input type="checkbox" name="permissions" value="<%= p %>"> <%= p %></label>
        <% }) %>
      </div>
      <div class="span"><button class="primary">Add subuser</button></div>
    </form>
    <table>
      <thead><tr><th>User</th><th>Permissions</th><th>Actions</th></tr></thead>
      <tbody>
        <% (server.subusers || []).forEach(su => { const sub = (allUsers || []).find(u => u.id === su.userId); %>
          <tr>
            <td><%= sub ? sub.email : su.userId %></td>
            <td><%= (su.permissions || []).join(', ') || 'None' %></td>
            <td><form method="post" action="/servers/<%= server.id %>/subusers/remove"><input type="hidden" name="userId" value="<%= su.userId %>"><button class="danger small-btn">Remove</button></form></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section id="tab-network" class="tab-panel">
  <div class="card">
    <div class="card-title-row"><h2>Network</h2><p class="muted">Main join address and extra port records.</p></div>
    <div class="chips"><span>Main IP: <%= server.ipAddress || 'not set' %></span><span>Main port: <%= server.port %></span></div>
    <form method="post" action="/servers/<%= server.id %>/network/ports" class="form settings-grid mt-12">
      <label>Extra port</label><input name="port" type="number" min="1" max="65535" placeholder="25566" required>
      <label>Type</label><select name="type"><option value="tcp">TCP</option><option value="udp">UDP</option></select>
      <label>Notes</label><input name="notes" placeholder="Voice chat, Dynmap, extra service">
      <div class="span"><button class="primary">Add port record</button></div>
    </form>
    <p class="muted small">This tracks ports for plans/orders. Live Docker rebinding for extra ports can be added next.</p>
    <table><thead><tr><th>Port</th><th>Type</th><th>Notes</th><th>Actions</th></tr></thead><tbody>
      <% (server.networkPorts || []).forEach(p => { %>
        <tr><td><%= p.port %></td><td><%= p.type %></td><td><%= p.notes || '' %></td><td><form method="post" action="/servers/<%= server.id %>/network/ports/remove"><input type="hidden" name="port" value="<%= p.port %>"><button class="danger small-btn">Remove</button></form></td></tr>
      <% }) %>
    </tbody></table>
  </div>
</section>


<section id="tab-subdomains" class="tab-panel">
  <div class="card">
    <div class="card-title-row"><h2>Subdomains</h2><p class="muted">Uses your user subdomain slots. You can add multiple domains to this server if you have free slots. Cloudflare DNS can be created automatically from panel/.env.</p></div>
    <% const ownerSubdomains = (allUsers || []).find(u => u.id === server.ownerId); %>
    <% const slots = ownerSubdomains ? (ownerSubdomains.subdomainSlots || 1) : 1; %>
    <p class="muted small">Owner slots: <%= (server.subdomains || []).length %> on this server. Total user slots are managed in Admin → Users.</p>
    <form method="post" action="/servers/<%= server.id %>/subdomains" class="form settings-grid">
      <label>Domain / subdomain</label><input name="hostname" placeholder="play.example.com" required>
      <label>Target</label><input name="target" value="<%= server.ipAddress || '' %>" placeholder="Server IP or CNAME target">
      <label>Port</label><input name="port" type="number" value="<%= server.port %>">
      <label>Game DNS type</label><select name="serviceType"><option value="java">Minecraft Java / Velocity / BungeeCord / Waterfall</option><option value="bedrock">Minecraft Bedrock / Geyser UDP</option><option value="rust">Rust</option><option value="other">Other</option></select>
      <div class="span"><button class="primary">Add subdomain</button></div>
    </form>
    <table>
      <thead><tr><th>Hostname</th><th>Target</th><th>Port</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>
      <% (server.subdomains || []).forEach(d => { %>
        <tr>
          <td><%= d.hostname %></td><td><%= d.target %></td><td><%= d.port %></td><td><%= d.status %></td>
          <td><form method="post" action="/servers/<%= server.id %>/subdomains/remove"><input type="hidden" name="subdomainId" value="<%= d.id %>"><button class="danger small-btn">Remove</button></form></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
    <p class="muted small">Cloudflare token, zone ID, and root domain live only in panel/.env. The token is never shown in the UI. For Minecraft, keep Cloudflare proxy off unless you use Spectrum.</p>
  </div>
</section>

<section id="tab-database" class="tab-panel">
  <div class="card">
    <div class="card-title-row"><h2>Databases</h2><p class="muted">Add database records for this server.</p></div>
    <form method="post" action="/servers/<%= server.id %>/databases" class="form settings-grid">
      <label>Name</label><input name="name" placeholder="survival_db">
      <label>Engine</label><select name="engine"><option value="mysql">MySQL/MariaDB</option><option value="postgres">PostgreSQL</option></select>
      <label>Username</label><input name="username" placeholder="db_user">
      <label>Host</label><input name="host" value="localhost">
      <label>Port</label><input name="port" value="3306">
      <div class="span"><button class="primary">Add database</button></div>
    </form>
    <table><thead><tr><th>Name</th><th>Engine</th><th>Host</th><th>User</th><th>Actions</th></tr></thead><tbody>
      <% (server.databases || []).forEach(db => { %>
        <tr><td><%= db.name %></td><td><%= db.engine %></td><td><%= db.host %>:<%= db.port %></td><td><%= db.username %></td><td><form method="post" action="/servers/<%= server.id %>/databases/remove"><input type="hidden" name="databaseId" value="<%= db.id %>"><button class="danger small-btn">Remove</button></form></td></tr>
      <% }) %>
    </tbody></table>
    <p class="muted small">Automatic MySQL/PostgreSQL creation can be wired to a DB node later.</p>
  </div>
</section>

<script>
async function loadStats() {
  try {
    const res = await fetch('/servers/<%= server.id %>/stats.json');
    const data = await res.json();
    if (!data.stats) return;
    document.getElementById('cpuStat').textContent = data.stats.docker.cpuPercent || '0%';
    document.getElementById('ramStat').textContent = data.stats.docker.memoryUsage || '0B / 0B';
    const usedMb = Math.ceil((data.stats.storage.usedBytes || 0) / 1024 / 1024);
    const limitMb = data.stats.storage.limitMb || 0;
    document.getElementById('storageStat').textContent = usedMb + ' MB / ' + limitMb + ' MB';
    if (data.stats.storage.disk && data.stats.storage.disk.availableBytes) {
      document.getElementById('diskStat').textContent = Math.floor(data.stats.storage.disk.availableBytes / 1024 / 1024 / 1024) + ' GB free';
    }
  } catch (e) {}
}
async function loadLogs() {
  const box = document.getElementById('consoleBox');
  try {
    const res = await fetch('/servers/<%= server.id %>/logs.json?lines=5000');
    const data = await res.json();
    box.textContent = data.logs || data.error || 'No logs yet.';
    box.scrollTop = box.scrollHeight;
  } catch (e) {
    box.textContent = e.message;
  }
}

function activateTab(name) {
  document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.tab === name));
  document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.toggle('active', panel.id === 'tab-' + name));
  if (history.replaceState) history.replaceState(null, '', '#'+name);
}
function activateSubtab(name) {
  document.querySelectorAll('.subtab-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.subtab === name));
  document.querySelectorAll('.subtab-panel').forEach(panel => panel.classList.toggle('active', panel.id === 'catalog-' + name));
}

document.querySelectorAll('.tab-btn').forEach(btn => btn.addEventListener('click', () => activateTab(btn.dataset.tab)));
document.querySelectorAll('.subtab-btn').forEach(btn => btn.addEventListener('click', () => activateSubtab(btn.dataset.subtab)));

const hash = (location.hash || '#console').replace('#', '');
activateTab(hash || 'console');
activateSubtab('all');

const searchInput = document.getElementById('catalogSearch');
if (searchInput) {
  searchInput.addEventListener('input', () => {
    const term = searchInput.value.trim().toLowerCase();
    document.querySelectorAll('#addonGrid .addon-card').forEach(card => {
      card.style.display = !term || card.dataset.search.includes(term) ? '' : 'none';
    });
  });
}


async function searchRealAddons() {
  const q = document.getElementById('realAddonSearch').value.trim();
  const source = document.getElementById('realAddonSource').value;
  const grid = document.getElementById('realAddonGrid');
  const status = document.getElementById('realAddonStatus');
  if (!q) { status.textContent = 'Type a search first.'; return; }
  status.textContent = 'Searching...';
  grid.innerHTML = '';
  try {
    const version = encodeURIComponent('<%= (settings && settings.settings && settings.settings.version) || "" %>');
    const res = await fetch(`/servers/<%= server.id %>/addons/search?q=${encodeURIComponent(q)}&source=${encodeURIComponent(source)}&version=${version}`);
    const data = await res.json();
    const results = data.results || [];
    if (!results.length) { status.textContent = 'No results found.'; return; }
    status.textContent = `${results.length} result(s) found.`;
    grid.innerHTML = results.map((item, i) => {
      if (item.error) return `<div class="addon-card"><div class="addon-top"><div class="addon-icon">!</div><div><h3>${item.source}</h3><p>${item.error}</p></div></div></div>`;
      const install = item.installUrl ? `
        <form method="post" action="/servers/<%= server.id %>/installer" class="addon-action">
          <input type="hidden" name="type" value="${escapeHtml(item.type || 'plugin')}">
          <input type="hidden" name="url" value="${escapeHtml(item.installUrl)}">
          <button>Install</button>
        </form>` : `<div class="addon-action"><a class="button" target="_blank" href="${escapeHtml(item.projectUrl || '#')}">Open page</a></div>`;
      const icon = item.iconUrl ? `<img src="${escapeHtml(item.iconUrl)}" alt="">` : escapeHtml((item.type || 'P').slice(0,1).toUpperCase());
      return `<div class="addon-card">
        <div class="addon-top">
          <div class="addon-icon">${icon}</div>
          <div><h3>${escapeHtml(item.name || 'Unknown')}</h3><p>${escapeHtml(item.description || '')}</p><p class="muted small">${escapeHtml(item.source || '')} · ${escapeHtml(item.type || 'plugin')}</p></div>
        </div>${install}</div>`;
    }).join('');
  } catch (e) {
    status.textContent = e.message;
  }
}
function escapeHtml(value) {
  return String(value || '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
}

setInterval(loadLogs, 5000);
setInterval(loadStats, 5000);
loadStats();
setTimeout(() => { const box = document.getElementById('consoleBox'); if (box) box.scrollTop = box.scrollHeight; }, 100);
</script>
<%- include('layout-bottom') %>
