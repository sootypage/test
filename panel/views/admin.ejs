<%- include('layout-top', { title }) %>
<section class="hero">
  <div>
    <h1>Admin</h1>
    <p>Manage nodes, users, servers, plans, API keys, and website provisioning.</p>
  </div>
</section>

<section class="tab-bar card">
  <button class="tab-btn active" data-tab="overview">Overview</button>
  <button class="tab-btn" data-tab="nodes">Nodes</button>
  <button class="tab-btn" data-tab="users">Users</button>
  <button class="tab-btn" data-tab="servers">Create server</button>
  <button class="tab-btn" data-tab="import">Import Docker</button>
  <button class="tab-btn" data-tab="resources">Server resources</button>
  <button class="tab-btn" data-tab="plans">Plans</button>
  <button class="tab-btn" data-tab="api">API / Website</button>
  <button class="tab-btn" data-tab="security">Security</button>
</section>

<section id="tab-overview" class="tab-panel active">
  <div class="grid">
    <div class="card"><h2>Users</h2><div class="stat"><strong><%= db.users.length %></strong><span>Total</span></div></div>
    <div class="card"><h2>Nodes</h2><div class="stat"><strong><%= db.nodes.length %></strong><span>Total</span></div></div>
    <div class="card"><h2>Servers</h2><div class="stat"><strong><%= db.servers.length %></strong><span>Total</span></div></div>
    <div class="card"><h2>API keys</h2><div class="stat"><strong><%= (db.apiKeys || []).filter(k => !k.revokedAt).length %></strong><span>Active</span></div></div>
  </div>
</section>

<section id="tab-nodes" class="tab-panel">
  <div class="card">
    <h2>Add Ubuntu node</h2>
    <form method="post" action="/admin/nodes" class="form two-col">
      <label>Name</label><input name="name" required placeholder="Sydney Node 1">
      <label>Agent URL</label><input name="url" required placeholder="http://1.2.3.4:4100">
      <label>Public IP</label><input name="publicIp" placeholder="38.87.117.169">
      <label>Agent token</label><input name="token" placeholder="Paste agent token if different from panel token">
      <label>Location</label><input name="location" placeholder="Australia">
      <button class="primary span">Add node</button>
    </form>
  </div>
  <div class="card">
    <h2>Nodes</h2>
    <table><thead><tr><th>Name</th><th>URL</th><th>Public IP</th><th>Location</th></tr></thead><tbody>
      <% db.nodes.forEach(n => { %><tr><td><%= n.name %></td><td><%= n.url %></td><td><%= n.publicIp || '' %></td><td><%= n.location %></td></tr><% }) %>
    </tbody></table>
  </div>
</section>

<section id="tab-users" class="tab-panel">
  <div class="card">
    <h2>Create user</h2>
    <form method="post" action="/admin/users" class="form two-col">
      <label>Name</label><input name="name" placeholder="User name">
      <label>Email</label><input name="email" type="email" required>
      <label>Password</label><input name="password" type="text" required>
      <label>Role</label><select name="role"><option value="user">User</option><option value="admin">Admin</option></select>
      <button class="primary span">Create user</button>
    </form>
  </div>
  <div class="card">
    <h2>Users</h2>
    <table><thead><tr><th>Email</th><th>Name</th><th>Role</th></tr></thead><tbody>
      <% db.users.forEach(u => { %><tr><td><%= u.email %></td><td><%= u.name %></td><td><%= u.role %></td></tr><% }) %>
    </tbody></table>
  </div>
</section>

<section id="tab-servers" class="tab-panel">
  <div class="card">
    <h2>Create Minecraft server</h2>
    <form method="post" action="/admin/servers" class="form two-col">
      <label>Server name</label><input name="name" required placeholder="survival-1">
      <label>Owner</label><select name="ownerId" required><% db.users.forEach(u => { %><option value="<%= u.id %>"><%= u.email %></option><% }) %></select>
      <label>Node</label><select name="nodeId" required><% db.nodes.forEach(n => { %><option value="<%= n.id %>"><%= n.name %> - <%= n.url %></option><% }) %></select>
      <label>Server type</label><select name="serverType"><option value="paper">Paper</option><option value="purpur">Purpur</option><option value="fabric">Fabric</option><option value="forge">Forge</option><option value="neoforge">NeoForge</option><option value="vanilla">Vanilla</option></select>
      <label>Game</label><input name="game" value="minecraft-paper">
      <label>Docker image</label><input name="image" value="itzg/minecraft-server:java21">
      <label>Minecraft version</label><input name="version" value="LATEST">
      <label>Memory limit MB</label><input name="memoryMb" type="number" value="2048">
      <label>CPU limit</label><input name="cpuLimit" type="number" step="0.25" value="1">
      <label>Storage limit MB</label><input name="storageLimitMb" type="number" value="10240">
      <label>Server IP</label><input name="ipAddress" placeholder="Leave blank to use node public IP">
      <label>Public port</label><input name="port" type="number" value="25565">
      <button class="primary span">Create server</button>
    </form>
  </div>
</section>


<section id="tab-import" class="tab-panel">
  <div class="card">
    <h2>Import old Docker containers</h2>
    <p class="muted">Scan a node for existing Docker containers and import them into the panel without deleting files. The container needs a <code>/data</code> volume mount so the panel can safely manage it.</p>
    <form method="get" action="/admin" class="form two-col">
      <label>Node to scan</label>
      <select name="importNodeId" required>
        <% db.nodes.forEach(n => { %>
          <option value="<%= n.id %>" <%= importNodeId === n.id ? 'selected' : '' %>><%= n.name %> - <%= n.url %></option>
        <% }) %>
      </select>
      <button class="primary span">Scan Docker containers</button>
    </form>
  </div>

  <div class="card">
    <h2>Containers found</h2>
    <% if (!db.nodes.length) { %>
      <p class="muted">Add a node first.</p>
    <% } else if (!(importContainers || []).length) { %>
      <p class="muted">No Docker containers found, or the node could not be scanned.</p>
    <% } else { %>
      <table>
        <thead><tr><th>Container</th><th>Status</th><th>Image</th><th>Ports</th><th>Data folder</th><th>Import</th></tr></thead>
        <tbody>
        <% (importContainers || []).forEach(c => { %>
          <tr>
            <td><strong><%= c.name %></strong><br><span class="muted small"><%= c.dockerId || '' %></span></td>
            <td><%= c.status || 'unknown' %><% if (c.alreadyImported) { %><br><span class="status online">Already imported</span><% } %></td>
            <td><%= c.image || '' %></td>
            <td>
              <% (c.ports || []).forEach(p => { %>
                <div><%= p.publicPort %> → <%= p.containerPort %>/<%= p.protocol %></div>
              <% }) %>
            </td>
            <td><span class="muted small"><%= c.dataMount && c.dataMount.source ? c.dataMount.source : 'No /data mount' %></span></td>
            <td>
              <% if (!c.alreadyImported && c.dataMount && c.dataMount.source) { %>
                <form method="post" action="/admin/import-container" class="mini-form">
                  <input type="hidden" name="nodeId" value="<%= importNodeId %>">
                  <input type="hidden" name="containerName" value="<%= c.name %>">
                  <label>Owner</label>
                  <select name="ownerId" required>
                    <% db.users.forEach(u => { %><option value="<%= u.id %>"><%= u.email %></option><% }) %>
                  </select>
                  <label>Panel name</label>
                  <input name="name" value="<%= c.name %>">
                  <label>Server type</label>
                  <select name="serverType">
                    <% ['paper','purpur','fabric','forge','neoforge','vanilla'].forEach(t => { %><option value="<%= t %>" <%= (c.serverType || 'paper') === t ? 'selected' : '' %>><%= t %></option><% }) %>
                  </select>
                  <label>Main public port</label>
                  <input name="port" type="number" value="<%= c.mainPort || 25565 %>">
                  <label>RAM MB</label>
                  <input name="memoryMb" type="number" value="<%= c.memoryMb || 2048 %>">
                  <label>CPU</label>
                  <input name="cpuLimit" type="number" step="0.25" value="<%= c.cpuLimit || 1 %>">
                  <label>Storage MB</label>
                  <input name="storageLimitMb" type="number" value="10240">
                  <button class="primary">Import</button>
                </form>
              <% } else if (!c.dataMount || !c.dataMount.source) { %>
                <span class="error small">Cannot import: no /data mount</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</section>

<section id="tab-resources" class="tab-panel">
  <div class="card">
    <h2>Edit server resources</h2>
    <p class="muted">Change RAM, CPU, and storage limits for existing servers. This recreates the Docker container safely and keeps the same files.</p>
    <table>
      <thead><tr><th>Server</th><th>Owner</th><th>RAM MB</th><th>CPU</th><th>Storage MB</th><th>Action</th></tr></thead>
      <tbody>
      <% db.servers.forEach(s => { const owner = db.users.find(u => u.id === s.ownerId); %>
        <tr>
          <form method="post" action="/admin/servers/<%= s.id %>/resources">
            <td><a href="/servers/<%= s.id %>"><%= s.name %></a></td>
            <td><%= owner ? owner.email : s.ownerId %></td>
            <td><input name="memoryMb" type="number" value="<%= s.memoryMb || 2048 %>" min="256"></td>
            <td><input name="cpuLimit" type="number" step="0.25" value="<%= s.cpuLimit || 1 %>" min="0.25"></td>
            <td><input name="storageLimitMb" type="number" value="<%= s.storageLimitMb || 10240 %>" min="1024"></td>
            <td><button class="primary small-btn">Save</button></td>
          </form>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section id="tab-plans" class="tab-panel">
  <div class="card">
    <h2>Plans</h2>
    <p class="muted">Use these values for your website checkout when calling the provision API.</p>
    <form method="post" action="/admin/plans" class="form two-col">
      <label>Plan name</label><input name="name" placeholder="Minecraft 4GB">
      <label>RAM MB</label><input name="memoryMb" type="number" value="4096">
      <label>CPU</label><input name="cpuLimit" type="number" step="0.25" value="2">
      <label>Storage MB</label><input name="storageLimitMb" type="number" value="20480">
      <label>Included extra ports</label><input name="extraPorts" type="number" value="0">
      <label>Included databases</label><input name="databases" type="number" value="0">
      <button class="primary span">Save plan</button>
    </form>
    <table><thead><tr><th>Name</th><th>RAM</th><th>CPU</th><th>Storage</th><th>Ports</th><th>Databases</th></tr></thead><tbody>
      <% (db.plans || []).forEach(p => { %><tr><td><%= p.name %></td><td><%= p.memoryMb %> MB</td><td><%= p.cpuLimit %></td><td><%= p.storageLimitMb %> MB</td><td><%= p.extraPorts %></td><td><%= p.databases %></td></tr><% }) %>
    </tbody></table>
  </div>
</section>

<section id="tab-api" class="tab-panel">
  <div class="card">
    <h2>API / Website linking</h2>
    <p class="muted">Create an admin API key with <strong>Website: create users</strong> and <strong>Website: create servers</strong> permissions, then your website can call the provision endpoint after checkout.</p>
    <div class="codebox">POST /api/v1/provision/order<br>Authorization: Bearer YOUR_API_KEY</div>
    <p class="muted small">Example JSON: email, name, serverName, planId, memoryMb, cpuLimit, storageLimitMb, port, version, orderId.</p>
    <a class="button primary" href="/api-keys">Manage API Keys</a>
  </div>
  <div class="card">
    <h2>Active API keys</h2>
    <table><thead><tr><th>Name</th><th>User</th><th>Permissions</th></tr></thead><tbody>
      <% (db.apiKeys || []).filter(k => !k.revokedAt).forEach(k => { const u = db.users.find(u => u.id === k.userId); %><tr><td><%= k.name %></td><td><%= u ? u.email : k.userId %></td><td><%= (k.permissions || []).join(', ') %></td></tr><% }) %>
    </tbody></table>
  </div>
</section>

<section id="tab-security" class="tab-panel">
  <div class="grid-2">
    <div class="card">
      <h2>Panel security</h2>
      <ul class="installed-list">
        <li><span>Helmet security headers</span><span>Enabled</span></li>
        <li><span>Login rate limit</span><span>20 / 15 min</span></li>
        <li><span>API rate limit</span><span>120 / min</span></li>
        <li><span>Secure cookies</span><span>Set COOKIE_SECURE=true when using HTTPS</span></li>
      </ul>
    </div>
    <div class="card">
      <h2>Node security checklist</h2>
      <ul class="installed-list">
        <li><span>Use a long AGENT_TOKEN</span><span>32+ chars</span></li>
        <li><span>Do not expose port 4100 publicly unless needed</span><span>Use firewall</span></li>
        <li><span>Allow only panel IP to node port</span><span>Recommended</span></li>
        <li><span>Use HTTPS/reverse proxy for panel</span><span>Recommended</span></li>
      </ul>
      <div class="codebox">sudo ufw allow from PANEL_IP to any port 4100 proto tcp</div>
    </div>
  </div>
</section>

<script>
function activateTab(name) {
  document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.tab === name));
  document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.toggle('active', panel.id === 'tab-' + name));
  if (history.replaceState) history.replaceState(null, '', '#'+name);
}
document.querySelectorAll('.tab-btn').forEach(btn => btn.addEventListener('click', () => activateTab(btn.dataset.tab)));
activateTab((location.hash || '#overview').replace('#',''));
</script>
<%- include('layout-bottom') %>
